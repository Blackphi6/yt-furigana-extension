{
  "manifest_version": 3,
  "name": "YT Furigana",
  "version": "1.9.0",
  "version_name": "1.9.0 (store-safe)",
  "description": "YouTube / TVer の日本語字幕にひらがなルビ（非公式）。端末内が既定・クリックで学習",
  "homepage_url": "https://blackphi6.github.io/yt-furigana-extension/",
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "*://www.youtube.com/*",
    "*://tver.jp/*",
    "https://yt-furigana-readings.onrender.com/*"
  ],
  "optional_host_permissions": [
    "http://localhost:11434/*",
    "http://127.0.0.1:11434/*",
    "http://127.0.0.1:8765/*",
    "http://localhost:8765/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ollama_origin",
        "enabled": true,
        "path": "rules/ollama.json"
      }
    ]
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "YT Furigana",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*", "*://tver.jp/*"],
      "js": ["dist/content.js"],
      "css": ["styles/content.css"],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-ancestors 'none';"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "dict/*",
        "dict/sudachi/*"
      ],
      "matches": ["*://www.youtube.com/*", "*://tver.jp/*"]
    }
  ]
}
